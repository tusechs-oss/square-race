Global="*uid://brmusfbv7xwb"
ImageHelper="*uid://bbnyamgrq18dh"

[editor_plugins]

enabled=PackedStringArray("res://addons/GodotTogether/plugin.cfg", "res://addons/PSDImporter/plugin.cfg", "res://addons/SimpleGodotAIAssistant/plugin.cfg", "res://addons/godot-socketio/plugin.cfg", "res://addons/godot_mcp/plugin.cfg", "res://addons/silent_wolf/plugin.cfg", "res://addons/trail_2d/plugin.cfg")

